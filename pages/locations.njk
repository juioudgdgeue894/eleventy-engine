---
# Programmatic local-SEO landing pages.
# One page is generated per entry in src/_data/towns.json, at /[slug_prefix][slug]/.
# This is the NEUTRAL, token-styled default — it adapts to any site theme and
# depends on no deprecated content partials. Bespoke sites usually replace it:
# disable via src/locations.11tydata.js (eleventyComputed.permalink -> false)
# and own the same URLs with site-owned partials (see CLAUDE.shared.md,
# "Bespoke location pages").
pagination:
  data: towns
  size: 1
  alias: town
layout: layouts/base.njk
permalink: "/{{ business.service_areas.slug_prefix }}{{ town.slug }}/"
eleventyExcludeFromCollections: true
eleventyComputed:
  title: "{{ town.title or (business.business_name + ' in ' + town.name) }}"
  description: "{{ town.meta or town.intro }}"
---
{# LOCATION HERO — area-specific headline + intro, data-driven from towns.json #}
<section class="border-b border-[var(--color-border)]">
  <div class="cd-container cd-section">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">{{ town.eyebrow or (business.business_name + " · " + town.name) }}</p>
      {% if town.headline %}<h1 class="mt-3 text-3xl font-medium leading-tight text-[var(--color-heading-text)] sm:text-4xl lg:text-5xl">{{ town.headline }}</h1>{% endif %}
      <div class="mt-8 max-w-2xl space-y-4 text-base leading-relaxed text-[var(--color-body-text)] sm:text-lg">
        <p>{{ town.intro }}</p>
        {% if town.local %}<p>{{ town.local }}</p>{% endif %}
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="#contact" class="cd-btn cd-btn-primary text-sm">{{ business.sections.hero.cta_primary_label }}</a>
        {% if business.sections.hero.cta_secondary_label %}<a href="/" class="cd-btn cd-btn-outline text-sm">{{ business.sections.hero.cta_secondary_label }}</a>{% endif %}
      </div>
    </div>
  </div>
</section>

{# CONTACT — intro + the engine's functional form core, token-styled #}
<section id="contact" class="scroll-mt-20">
  <div class="cd-container cd-section grid grid-cols-1 gap-12 lg:grid-cols-2">
    <div>
      <h2 class="text-2xl font-medium text-[var(--color-heading-text)] sm:text-3xl">{{ business.sections.contact.side_heading or business.sections.contact.heading }}</h2>
      <p class="mt-6 max-w-md leading-relaxed text-[var(--color-body-text)]">{{ business.sections.contact.side_text or business.sections.contact.intro }}</p>
      <p class="mt-8 text-sm">
        <a class="text-[var(--color-heading-text)] underline" href="mailto:{{ business.contact.email }}">{{ business.contact.email }}</a>
      </p>
    </div>
    <form class="space-y-4" method="POST" action="/api/contact">
      {% include "partials/contact-fields.njk" %}
    </form>
  </div>
</section>
