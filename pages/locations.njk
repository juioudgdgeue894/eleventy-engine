---
# Programmatic local-SEO landing pages.
# One page is generated per entry in src/_data/towns.json, at /[location-slug]/.
# Edit the area data in towns.json; this template controls the layout.
pagination:
  data: towns
  size: 1
  alias: town
layout: layouts/base.njk
permalink: "/{{ business.service_areas.slug_prefix }}{{ town.slug }}/"
eleventyExcludeFromCollections: true
eleventyComputed:
  title: "{{ town.title or (business.business_name + ' in ' + town.name) }}"
  description: "{{ town.meta or town.intro }}"
---
<!-- LOCATION HERO — area-specific headline + intro, data-driven from towns.json -->
<section class="bg-gradient-to-b from-[var(--color-secondary)] to-[var(--color-bg)]">
  <div class="cd-container cd-section">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">{{ town.eyebrow or (business.business_name + " · " + town.name) }}</p>
      {% if town.headline %}<h1 class="mt-3 text-3xl font-medium leading-tight text-white sm:text-4xl lg:text-5xl">{{ town.headline }}</h1>{% endif %}
      <div class="mt-8 max-w-2xl space-y-4 text-base leading-relaxed text-[var(--color-body-text)] sm:text-lg">
        <p>{{ town.intro }}</p>
        <p>{{ town.local }}</p>
      </div>
      <div class="mt-10 flex flex-wrap gap-4">
        <a href="{{ business.sections.hero.cta_primary_href }}" class="cd-btn cd-btn-primary text-sm">{{ business.sections.hero.cta_primary_label }}</a>
        <a href="{{ business.sections.hero.cta_secondary_href }}" class="cd-btn cd-btn-outline text-sm">{{ business.sections.hero.cta_secondary_label }}</a>
      </div>
    </div>
  </div>
</section>
{% include "partials/services.njk" %}
{% include "partials/work.njk" %}
{% include "partials/contact-form.njk" %}
