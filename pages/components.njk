    </section>
  {% endcall %}

  <h2 id="cat-process" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Process</h2>
  {% call card("Process", "Numbered how-it-works steps", "steps-01", "Custom") %}
    {% set steps = [
      { "n": "01", "title": "Discover", "desc": "We learn about your business and goals." },
      { "n": "02", "title": "Design", "desc": "Wireframes and visuals before any code." },
      { "n": "03", "title": "Build", "desc": "Fast, accessible, mobile-first development." },
      { "n": "04", "title": "Launch", "desc": "Live, tested, and handed over to you." }
    ] %}
    <section class="bg-white">
      <div class="cd-container cd-section">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl sm:text-4xl">How We Work</h2>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-4">
          {% for step in steps %}
          <div>
            <span class="text-3xl font-light text-[var(--color-primary)]/40">{{ step.n }}</span>
            <h3 class="mt-2 text-lg">{{ step.title }}</h3>
            <p class="mt-1 text-sm text-gray-600">{{ step.desc }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}

  {% call card("Process", "Vertical timeline", "steps-02", "Preline-style") %}
    {% set steps_v2 = [
      { "n": "01", "title": "Discover", "desc": "We learn about your business and goals." },
      { "n": "02", "title": "Design", "desc": "Wireframes and visuals before any code." },
      { "n": "03", "title": "Build", "desc": "Fast, accessible, mobile-first development." },
      { "n": "04", "title": "Launch", "desc": "Live, tested, and handed over to you." }
    ] %}
    <section class="bg-gray-50">
      <div class="cd-container cd-section">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <h2 class="text-3xl sm:text-4xl">How We Work</h2>
        </div>
        <div class="relative mx-auto max-w-lg">
          <div class="absolute bottom-0 left-6 top-0 w-px bg-gray-200"></div>
          {% for step in steps_v2 %}
          <div class="relative flex gap-6 pb-10 last:pb-0">
            <div class="z-10 flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-[var(--color-primary)] text-sm font-semibold text-white">{{ step.n }}</div>
            <div class="pt-2">
              <h3 class="font-semibold">{{ step.title }}</h3>
              <p class="mt-1 text-sm text-gray-600">{{ step.desc }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Process", "Numbered dark cards", "steps-03", "Flowbite-style") %}
    {% set steps_v3 = [
      { "n": "01", "title": "Discover", "desc": "We learn about your business and goals." },
      { "n": "02", "title": "Design", "desc": "Wireframes and visuals before any code." },
      { "n": "03", "title": "Build", "desc": "Fast, accessible, mobile-first development." },
      { "n": "04", "title": "Launch", "desc": "Live, tested, and handed over to you." }
    ] %}
    <section class="bg-[var(--color-secondary)]">
      <div class="cd-container cd-section">
        <div class="mx-auto mb-10 max-w-2xl text-center">
          <h2 class="text-3xl text-white">How We Work</h2>
        </div>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {% for step in steps_v3 %}
          <div class="cd-rounded-img border border-white/10 bg-white/5 p-6">
            <span class="text-2xl font-light text-[var(--color-primary)]/60">{{ step.n }}</span>
            <h3 class="mt-3 font-semibold text-white">{{ step.title }}</h3>
            <p class="mt-1 text-sm text-white/60">{{ step.desc }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}

  <h2 id="cat-contact" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Contact</h2>
  {% call card("Contact", "Two-column - intro + message form", "contact-02", "Custom") %}
    <section id="contact" class="bg-[var(--color-secondary)]">
      <div class="cd-container cd-section grid grid-cols-1 gap-12 lg:grid-cols-2">
        <div>
          <h2 class="text-2xl font-medium text-white sm:text-3xl">{{ business.sections.contact.side_heading }}</h2>
          <p class="mt-6 max-w-md leading-relaxed text-[var(--color-body-text)]">{{ business.sections.contact.side_text }}</p>
          <ul class="mt-8 space-y-3 text-sm">
            <li>
              <a class="inline-flex items-center gap-3 text-[var(--color-body-text)] transition hover:text-white" href="mailto:{{ business.contact.email }}">
                <svg class="h-4 w-4 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                {{ business.contact.email }}
              </a>
            </li>
            {% for s in business.social %}
            <li>
              <a class="inline-flex items-center gap-3 text-[var(--color-body-text)] transition hover:text-white" href="{{ s.url }}" target="_blank" rel="noopener">
                <span class="text-[var(--color-primary)]">↗</span>{{ s.label }}<span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>

        <div>
          <h3 class="text-lg font-medium text-white">{{ business.sections.contact.heading }}</h3>
          <form class="mt-6 space-y-4" method="POST" action="#" name="contact" data-netlify="true" data-netlify-honeypot="bot-field">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden" aria-hidden="true"><label>Don't fill this out: <input name="bot-field" tabindex="-1" /></label></p>
            <div>
              <label class="sr-only" for="name">Full name</label>
              <input class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-primary)] focus:outline-none" type="text" name="name" id="name" placeholder="Name" autocomplete="name" required />
            </div>
            <div>
              <label class="sr-only" for="email">Email address</label>
              <input class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-primary)] focus:outline-none" type="email" name="email" id="email" placeholder="Email" autocomplete="email" required />
            </div>
            <div>
              <label class="sr-only" for="message">Message</label>
              <textarea class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-primary)] focus:outline-none" rows="6" name="message" id="message" placeholder="Message" required></textarea>
            </div>
            <button class="cd-btn cd-btn-primary w-full text-sm sm:w-auto" type="submit">Send message</button>
            <p class="text-xs text-[var(--color-body-text)]">By sending this message you agree to our <a class="underline hover:text-white" href="/privacy-policy/">Privacy Policy</a>.</p>
          </form>
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Contact", "Phone / email / address cards", "contact-info-01", "Custom") %}
    <section class="bg-gray-50">
      <div class="cd-container cd-section">
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
          <div class="cd-rounded-img bg-white p-6 text-center shadow-sm">
            <p class="text-sm text-gray-500">Phone</p>
            <a class="mt-1 block text-lg text-[var(--color-primary)]" href="{{ business.contact.phone_href }}">{{ business.contact.phone }}</a>
          </div>
          <div class="cd-rounded-img bg-white p-6 text-center shadow-sm">
            <p class="text-sm text-gray-500">Email</p>
            <a class="mt-1 block text-lg text-[var(--color-primary)]" href="mailto:{{ business.contact.email }}">{{ business.contact.email }}</a>
          </div>
          <div class="cd-rounded-img bg-white p-6 text-center shadow-sm">
            <p class="text-sm text-gray-500">Address</p>
            <p class="mt-1 text-lg">{{ business.address.city }}, {{ business.address.region }}</p>
          </div>
        </div>
      </div>
    </section>
  {% endcall %}

  {% call card("Contact", "Map placeholder + details panel", "contact-info-02", "Custom") %}
    <section class="bg-white">
      <div class="cd-container cd-section grid grid-cols-1 items-start gap-8 lg:grid-cols-2">
        <div class="cd-rounded-img flex aspect-video w-full items-center justify-center bg-gray-100 text-sm text-gray-400">
          Map embed here (Google Maps / Mapbox iframe)
        </div>
        <div class="space-y-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Address</p>
            <p class="mt-1 text-gray-900">{{ business.address.line1 }}, {{ business.address.city }}, {{ business.address.postcode }}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Phone</p>
            <a class="mt-1 block text-[var(--color-primary)]" href="{{ business.contact.phone_href }}">{{ business.contact.phone }}</a>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Email</p>
            <a class="mt-1 block text-[var(--color-primary)]" href="mailto:{{ business.contact.email }}">{{ business.contact.email }}</a>
          </div>
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Contact", "Dark inline contact bar", "contact-info-03", "Oxbow-style") %}
    <section class="bg-[var(--color-secondary)]">
      <div class="cd-container flex flex-col items-center justify-center gap-6 py-8 sm:flex-row sm:gap-12">
        <a class="flex items-center gap-3 text-white transition hover:text-[var(--color-primary-light)]" href="{{ business.contact.phone_href }}">
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          <span class="text-sm">{{ business.contact.phone }}</span>
        </a>
        <div class="hidden h-6 w-px bg-white/20 sm:block"></div>
        <a class="flex items-center gap-3 text-white transition hover:text-[var(--color-primary-light)]" href="mailto:{{ business.contact.email }}">
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          <span class="text-sm">{{ business.contact.email }}</span>
        </a>
        <div class="hidden h-6 w-px bg-white/20 sm:block"></div>
        <span class="flex items-center gap-3 text-sm text-white/60">
          <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          {{ business.address.city }}, {{ business.address.region }}
        </span>
      </div>
    </section>
  {% endcall %}

</div>

<script>
  document.querySelectorAll(".copy-id-btn").forEach(function (btn) {
    var label = btn.querySelector(".copy-label");
    var original = label.textContent;
    btn.addEventListener("click", function () {
      navigator.clipboard.writeText(btn.dataset.copyId).then(function () {
        label.textContent = "Copied!";
        setTimeout(function () { label.textContent = original; }, 1200);
      });
    });
  });
</script>
