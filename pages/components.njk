---
layout: layouts/bare.njk
title: Component Library
permalink: components/index.html
eleventyExcludeFromCollections: true
---
{% macro label(category, name, id, source) %}
<div class="flex items-center justify-between gap-3 border-b border-gray-200 bg-white px-4 py-2.5">
  <div class="flex items-center gap-2">
    <span class="text-sm font-semibold text-gray-900">{{ name }}</span>
    <span class="text-xs text-gray-400">{{ category }}</span>
    {% if source %}<span class="rounded-full bg-gray-100 px-2 py-0.5 text-[10px] font-medium text-gray-500">{{ source }}</span>{% endif %}
  </div>
  <button type="button" class="copy-id-btn inline-flex items-center gap-1.5 rounded-md border border-gray-200 bg-gray-50 px-2.5 py-1 text-xs font-mono text-gray-600 hover:bg-gray-100" data-copy-id="{{ id }}">
    <span class="copy-label">{{ id }}</span>
    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
    </svg>
  </button>
</div>
{% endmacro %}

{% macro card(category, name, id, source) %}
<section class="mb-10 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
  {{ label(category, name, id, source) }}
  <div class="overflow-hidden">
    {{ caller() }}
  </div>
</section>
{% endmacro %}

{# Placeholder-safe fallbacks — the library must render on ANY site, including
   ones whose business.json leaves these arrays empty. Indexed access on an
   empty array is fine in Nunjucks, but piping the result through a filter
   (e.g. `| first`) throws, and empty showcases look broken; so every indexed
   showcase below draws from these instead. #}
{% set libStat = business.stats[0] if business.stats and business.stats.length else {"value": "10+", "label": "Years of experience"} %}
{% set libTestimonial = business.testimonials[0] if business.testimonials and business.testimonials.length else {"quote": "A short, specific, believable client quote goes here.", "name": "Client Name", "role": "Role / Company"} %}
{% set libAboutPara = business.about.paragraphs[0] if business.about and business.about.paragraphs and business.about.paragraphs.length else "About paragraph placeholder - your story, background, and what you do." %}

<div class="sticky top-0 z-20 border-b border-gray-200 bg-white/95 backdrop-blur">
  <div class="mx-auto max-w-5xl px-4 py-4">
    <h1 class="text-lg font-semibold">Component Library</h1>
    <p class="mt-0.5 text-sm text-gray-500">
      Click the ID badge on any component to copy it, then tell me which one(s) you want added or swapped in.
      "Source" tags show the stylistic family each one is drawn from - everything is restyled with this
      site's own colour/spacing tokens, so they all interoperate regardless of where the pattern originated.
    </p>
    <nav class="mt-3 flex flex-wrap gap-3 text-xs">
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-header">Header</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-statement">Statement</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-hero">Hero</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-stats">Stats</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-services">Services</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-portfolio">Portfolio</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-pricing">Pricing</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-about">About</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-team">Team</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-testimonials">Testimonials</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-faq">FAQ</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-gallery">Gallery</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-booking">Booking</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-cta">CTA</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-forms">Forms</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-footer">Footer</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-announcement">Announcement</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-elements">UI Elements</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-tables">Tables</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-interactive">Interactive</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-blog">Blog</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-logos">Social Proof</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-process">Process</a>
      <a class="text-[var(--color-primary)] hover:underline" href="#cat-contact">Contact</a>
    </nav>
  </div>
</div>

<div class="mx-auto max-w-5xl px-4 py-10">

  <h2 id="cat-header" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Header</h2>
  {% call card("Header", "Sticky nav + utility bar (current)", "header-01", "Custom") %}
    <div class="overflow-hidden">{% include "partials/header.njk" %}</div>
  {% endcall %}
  {% call card("Header", "Simple centered logo", "navbar-02", "Custom") %}
    <nav class="border-b border-gray-100 bg-white">
      <div class="cd-container flex h-16 items-center justify-center gap-10">
        <a class="text-sm text-gray-500 hover:text-[var(--color-primary)]" href="#">Services</a>
        <a class="text-sm text-gray-500 hover:text-[var(--color-primary)]" href="#">Work</a>
        <span class="text-xl text-[var(--color-primary)]">{{ business.brand_name_primary }}</span>
        <a class="text-sm text-gray-500 hover:text-[var(--color-primary)]" href="#">Pricing</a>
        <a class="text-sm text-gray-500 hover:text-[var(--color-primary)]" href="#">Contact</a>
      </div>
    </nav>
  {% endcall %}
  {% call card("Header", "With dropdown menu (functional)", "navbar-03", "Preline-style") %}
    <nav class="overflow-visible border-b border-gray-100 bg-white">
      <div class="cd-container flex h-16 items-center justify-between">
        <span class="text-xl text-[var(--color-primary)]">{{ business.brand_name_primary }}<span class="text-gray-900">{{ business.brand_name_accent }}</span></span>
        <div class="hidden items-center gap-6 sm:flex">
          <button id="nav-dropdown-btn" data-dropdown-toggle="nav-dropdown" class="flex items-center gap-1 text-sm text-gray-500 hover:text-[var(--color-primary)]" type="button">
            Services
            <svg class="h-3 w-3" fill="none" viewBox="0 0 10 6" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1l4 4 4-4" /></svg>
          </button>
          <a class="text-sm text-gray-500 hover:text-[var(--color-primary)]" href="#">Pricing</a>
          <a class="cd-btn cd-btn-primary text-sm" href="#">Contact</a>
        </div>
      </div>
      <div id="nav-dropdown" class="z-20 hidden w-44 cd-rounded-img bg-white shadow-lg">
        <ul class="py-2 text-sm text-gray-600">
          {% for service in business.services %}
          <li><a class="block px-4 py-2 hover:bg-gray-50" href="#{{ service.slug }}">{{ service.name }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </nav>
  {% endcall %}

  <h2 id="cat-statement" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Statement</h2>
  {% call card("Statement", "Dark editorial large-text mission block", "statement-01", "Custom") %}
    <section class="bg-[var(--color-secondary)]">
      <div class="cd-container cd-section">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">About</p>
        <p class="mt-6 max-w-4xl text-2xl font-medium leading-snug text-white sm:text-3xl lg:text-4xl">
          I've built websites for tattoo studios, beauty salons, property managers, and personal chefs.
          The focus stays the same: <span class="cd-highlight">sites that actually work</span>,
          <span class="cd-highlight">automation that saves real time</span>,
          and digital strategy that moves the needle - not vanity metrics.
        </p>
        <div class="mt-10 flex items-center gap-4">
          <div class="h-px flex-1 bg-white/10"></div>
          <a href="#about" class="text-sm font-semibold text-white hover:text-[var(--color-primary)]">More about me →</a>
        </div>
      </div>
    </section>
  {% endcall %}

  <h2 id="cat-hero" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Hero</h2>
  {% call card("Hero", "Intro statement + tech stack pills", "hero-05", "Custom") %}
    <section class="bg-gradient-to-b from-[var(--color-secondary)] to-[var(--color-bg)]">
      <div class="cd-container cd-section">
        <div class="max-w-3xl">
          <h1 class="text-3xl font-medium leading-tight text-white sm:text-4xl lg:text-5xl">{{ business.sections.hero.heading }}</h1>
          <div class="mt-8 max-w-2xl space-y-4 text-base leading-relaxed text-[var(--color-body-text)] sm:text-lg">
            {% for para in business.sections.hero.intro_paragraphs %}
            <p>{{ para }}</p>
            {% endfor %}
          </div>
          <div class="mt-10">
            <p class="text-sm text-[var(--color-body-text)]">{{ business.sections.hero.stack_label }}</p>
            <ul class="mt-4 flex flex-wrap gap-2.5">
              {% for tech in business.stack %}
              <li class="rounded-[var(--radius-button)] border border-white/10 bg-white/[0.02] px-3 py-1.5 text-xs font-medium text-[var(--color-body-text)]">{{ tech }}</li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Hero", "Split, image + stats (current)", "hero-01", "Custom") %}
    {% include "partials/hero.njk" %}
  {% endcall %}
  {% call card("Hero", "Simple centered", "hero-02", "Custom") %}
    <section class="bg-white">
      <div class="cd-container cd-section text-center">
        <h1 class="mx-auto max-w-2xl text-4xl sm:text-5xl">{{ business.tagline }}</h1>
        <p class="mx-auto mt-4 max-w-xl text-lg text-gray-600">{{ business.description }}</p>
        <div class="mt-8 flex justify-center gap-4">
          <a class="cd-btn cd-btn-primary text-sm" href="#">Get Started</a>
          <a class="cd-btn cd-btn-outline text-sm" href="#">Learn More</a>
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Hero", "Dark editorial text-dominant with arrow CTAs", "hero-04", "Custom") %}
    <section class="bg-[var(--color-bg)]">
      <div class="cd-container py-16">
        <div class="mb-10 inline-flex items-center gap-2.5 text-xs font-medium text-emerald-400">
          <span class="h-2 w-2 rounded-full bg-emerald-400"></span>
          Available for projects
        </div>
        <h1 class="text-6xl font-black leading-none tracking-tight text-white">{{ business.brand_name_primary }}<br>{{ business.brand_name_accent }}</h1>
        <p class="mt-6 max-w-xl text-lg text-[var(--color-body-text)]">{{ business.tagline }}</p>
        <div class="mt-8 flex flex-wrap items-center gap-6">
          <a href="#contact" class="group flex items-center gap-3 text-sm font-semibold text-white">
            <span class="flex h-10 w-10 items-center justify-center border border-white/25 text-base transition group-hover:bg-white group-hover:text-[var(--color-bg)]">→</span>
            Book a Free Call
          </a>
          <a href="#work" class="group flex items-center gap-3 text-sm font-semibold text-[var(--color-body-text)] transition hover:text-white">
            <span class="flex h-10 w-10 items-center justify-center border border-white/10 text-base">→</span>
            See My Work
          </a>
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Hero", "Centered with badge + trust line", "hero-03", "Preline-style") %}
    <section class="bg-gray-50">
      <div class="cd-container cd-section text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-gray-200 bg-white px-4 py-1.5 text-xs font-medium text-gray-600">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-primary)]"></span>
          {{ libStat.value }} {{ libStat.label | lower }}
        </span>
        <h1 class="mx-auto mt-6 max-w-3xl text-4xl sm:text-6xl">{{ business.tagline }}</h1>
        <p class="mx-auto mt-4 max-w-xl text-lg text-gray-600">{{ business.description }}</p>
        <div class="mt-8 flex justify-center gap-4">
          <a class="cd-btn cd-btn-primary text-sm shadow-lg" href="#">Start a Project</a>
          <a class="cd-btn cd-btn-outline text-sm" href="#">View Our Work</a>
        </div>
        <p class="mt-10 text-xs uppercase tracking-wide text-gray-400">[Trust line — e.g. 'Trusted by businesses across [region]']</p>
      </div>
    </section>
  {% endcall %}

  <h2 id="cat-stats" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Stats</h2>
  {% call card("Stats", "Three-up stat band (current)", "stats-01", "Custom") %}
    {% include "partials/stats.njk" %}
  {% endcall %}
  {% call card("Stats", "Horizontal divider band", "stats-03", "Flowbite-style") %}
    <section class="bg-[var(--color-secondary)]">
      <div class="cd-container cd-section grid grid-cols-1 divide-y divide-white/10 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
        {% for stat in business.stats %}
        <div class="px-6 py-6 text-center">
          <p class="text-3xl text-white">{{ stat.value }}</p>
          <p class="mt-1 text-sm text-white/60">{{ stat.label }}</p>
        </div>
        {% endfor %}
      </div>
    </section>
  {% endcall %}
  {% call card("Stats", "Icon + number cards", "stats-02", "Oxbow-style") %}
    <section class="bg-white">
      <div class="cd-container cd-section grid grid-cols-1 gap-6 sm:grid-cols-3">
        {% for stat in business.stats %}
        <div class="flex items-center gap-4 cd-rounded-img border border-gray-100 p-6">
          <span class="flex h-12 w-12 shrink-0 items-center justify-center cd-rounded-img bg-[var(--color-primary-light)] text-[var(--color-primary)]">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
          </span>
          <div>
            <p class="text-2xl text-gray-900">{{ stat.value }}</p>
            <p class="text-sm text-gray-500">{{ stat.label }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </section>
  {% endcall %}

  <h2 id="cat-services" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Services</h2>
  {% call card("Services", "Icon cards - featured first, balanced grid", "services-05", "Custom") %}
    {% set svcIcons = {
      "code": "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
      "search": "m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z",
      "spark": "M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z",
      "design": "m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z",
      "support": "M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z",
      "cart": "M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"
    } %}
    {% set total = business.services | length %}
    <section id="services">
      <div class="cd-container cd-section">
        <h2 class="text-2xl font-medium text-white sm:text-3xl">{{ business.sections.services.heading }}</h2>
        <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {% for service in business.services %}
          {% set isFull = loop.first or (loop.last and total % 2 == 0) %}
          <div class="{{ 'sm:col-span-2' if isFull else '' }} group rounded-[var(--radius-image)] border border-white/10 bg-white/[0.02] p-6 transition hover:border-white/20 hover:bg-white/[0.04]">
            <span class="flex h-10 w-10 items-center justify-center rounded-[var(--radius-button)] border border-white/10 text-[var(--color-primary)]">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="{{ svcIcons[service.icon] }}" />
              </svg>
            </span>
            <h3 class="mt-5 text-lg font-medium text-white">{{ service.name }}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--color-body-text)]">{{ service.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Services", "Icon-circle card grid (current)", "services-01", "Custom") %}
    {% include "partials/services.njk" %}
  {% endcall %}
  {% call card("Services", "Two-column list with arrow links", "services-02", "Preline-style") %}
    <section class="bg-white">
      <div class="cd-container cd-section">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl sm:text-4xl">What We Do</h2>
        </div>
        <div class="mt-12 grid grid-cols-1 gap-x-12 gap-y-6 sm:grid-cols-2">
          {% for service in business.services %}
          <a class="group flex items-start justify-between gap-4 border-b border-gray-100 py-4" href="#{{ service.slug }}">
            <div>
              <h3 class="text-lg">{{ service.name }}</h3>
              <p class="mt-1 text-sm text-gray-600">{{ service.description }}</p>
            </div>
            <svg class="mt-1 h-5 w-5 shrink-0 text-[var(--color-primary)] transition group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Services", "Dark editorial accordion with + icon", "services-04", "Custom") %}
    <section class="bg-[var(--color-bg)] py-10">
      <div class="cd-container">
        <div class="mb-6 border-b border-white/10 pb-6">
          <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">What I Do</span>
          <h2 class="mt-3 text-2xl font-black text-white">Services</h2>
        </div>
        <div data-accordion="collapse">
          {% for service in business.services %}
          <h3 id="lib-svc-heading-{{ loop.index }}">
            <button type="button"
              class="group flex w-full items-center justify-between gap-4 border-b border-white/10 py-5 text-left"
              data-accordion-target="#lib-svc-body-{{ loop.index }}"
              aria-expanded="{{ 'true' if loop.first else 'false' }}"
              aria-controls="lib-svc-body-{{ loop.index }}">
              <span class="flex items-center gap-5">
                <span class="font-mono text-xs text-[var(--color-body-text)]">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                <span class="font-semibold text-white group-hover:text-[var(--color-primary)] transition">{{ service.name }}</span>
              </span>
              <span class="svc-acc-icon text-xl font-light text-[var(--color-body-text)]">+</span>
            </button>
          </h3>
          <div id="lib-svc-body-{{ loop.index }}" class="{{ '' if loop.first else 'hidden' }}" aria-labelledby="lib-svc-heading-{{ loop.index }}">
            <p class="py-5 pl-10 text-sm text-[var(--color-body-text)]">{{ service.description }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}
  {% call card("Services", "Numbered minimal list", "services-03", "Oxbow-style") %}
    <section class="bg-gray-50">
      <div class="cd-container cd-section">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl sm:text-4xl">What We Do</h2>
        </div>
        <div class="mx-auto mt-12 max-w-2xl divide-y divide-gray-200">
          {% for service in business.services %}
          <div class="flex items-start gap-4 py-5">
            <span class="text-sm font-mono text-[var(--color-primary)]">{{ loop.index }}</span>
            <div>
              <h3 class="font-semibold">{{ service.name }}</h3>
              <p class="mt-1 text-sm text-gray-600">{{ service.description }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
  {% endcall %}

  <h2 id="cat-portfolio" class="mb-4 scroll-mt-32 text-xs font-semibold uppercase tracking-wide text-gray-400">Portfolio</h2>
  {% call card("Portfolio", "Project cards - preview + label below", "work-05", "Custom") %}
    {% set gradients = {
      "primary": "from-[var(--color-primary)] to-[var(--color-primary-dark)]",
      "secondary": "from-[var(--color-secondary)] to-[var(--color-secondary-dark)]",
      "accent": "from-[var(--color-accent)] to-[var(--color-accent-dark)]"
    } %}
    <section id="work" class="bg-[var(--color-secondary)]">
      <div class="cd-container cd-section">
        <h2 class="text-2xl font-medium text-white sm:text-3xl">{{ business.sections.work.heading }}</h2>
        <div class="mt-10 grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2">
          {% for project in business.portfolio %}
          <a class="group block" href="{{ project.href }}" target="_blank" rel="noopener">
            {% if project.image %}
            <div class="relative flex aspect-[5/4] items-center justify-center overflow-hidden rounded-[var(--radius-image)] border border-white/10 bg-[var(--color-bg)] transition group-hover:border-white/25">
              {# Library preview uses plain <img> - the async {% image %} shortcode can't render inside a Nunjucks macro caller. The live partial (work.njk) uses the optimised shortcode. #}
              <div class="absolute inset-0 scale-125 bg-cover bg-center blur-2xl opacity-40" style="background-image:url(/images/{{ project.image }})" aria-hidden="true"></div>
              <div class="absolute inset-0 bg-black/50" aria-hidden="true"></div>
              <div class="relative w-[84%] overflow-hidden rounded-[var(--radius-image)] border border-white/15 shadow-2xl shadow-black/60">
                <div class="flex items-center gap-2 bg-[#3a3a3e] px-3 py-1">
                  <span class="flex shrink-0 gap-1.5">
                    <span class="h-2.5 w-2.5 bg-[#ff5f57]" style="border-radius:9999px"></span>
                    <span class="h-2.5 w-2.5 bg-[#febc2e]" style="border-radius:9999px"></span>
