---
layout: layouts/base.njk
permalink: blog/index.html
eleventyComputed:
  title: "{{ business.blog.title or (business.blog.heading or 'Blog') }}"
  description: "{{ business.blog.description or business.blog.intro }}"
---
<section>
  <div class="cd-container cd-section">
    <div class="mx-auto max-w-2xl text-center">
      {#- The h1 always renders (every indexable page needs exactly one), falling
         back to the page title. Colour comes from the site token rather than
         text-white so the fallback stays legible on light themes; the eyebrow is
         suppressed when it would just duplicate the h1 text. -#}
      {%- set _blogH1 = business.blog.heading or business.blog.title or "Blog" -%}
      {%- set _blogEyebrow = business.blog.eyebrow or "Blog" -%}
      {% if _blogEyebrow != _blogH1 %}<span class="text-xs font-semibold uppercase tracking-wide text-[var(--color-accent-link)]">{{ _blogEyebrow }}</span>{% endif %}
      <h1 class="mt-2 text-3xl font-medium text-[var(--color-heading-text,#fff)] sm:text-4xl">{{ _blogH1 }}</h1>
      {% if business.blog.intro %}<p class="mt-4 text-[var(--color-body-text)]">{{ business.blog.intro }}</p>{% endif %}
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {% for post in collections.posts | reverse %}
      <a class="group flex flex-col rounded-[var(--radius-image)] border border-white/10 bg-[var(--color-secondary)] p-6 transition hover:border-white/25 hover:bg-[var(--color-secondary-dark)]" href="{{ post.url }}">
        <div class="flex items-center gap-2 text-xs uppercase tracking-wide text-[var(--color-accent-link)]">
          <span>{{ post.templateContent | readingTime }} min read</span>
        </div>
        <h2 class="mt-3 text-lg font-medium leading-snug text-white group-hover:text-white">{{ post.data.title }}</h2>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-[var(--color-body-text)]">{{ post.data.description }}</p>
        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-accent-link)] group-hover:text-white">
          Read article
          <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
        </span>
      </a>
      {% endfor %}
    </div>

    {# Empty state — a bare heading with nothing under it looks broken #}
    {% if not collections.posts.length %}
    <div class="mx-auto mt-14 max-w-md text-center">
      <p class="text-white">No articles yet.</p>
      <p class="mt-2 text-sm text-[var(--color-body-text)]">New posts land here first — in the meantime, <a class="underline hover:text-white" href="/#contact">get in touch</a> with any questions.</p>
    </div>
    {% endif %}
  </div>
</section>
