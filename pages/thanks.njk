---
layout: layouts/base.njk
title: Thanks - message received
description: Thanks for getting in touch.
noindex: true
eleventyExcludeFromCollections: true
---
<section class="cd-container cd-section">
  <div class="mx-auto max-w-xl text-center">
    <h1 class="text-3xl font-medium text-white sm:text-4xl">{{ business.thanks.heading or "Thanks - message received." }}</h1>
    {% if business.thanks.message %}<p class="mt-6 leading-relaxed text-[var(--color-body-text)]">
      {{ business.thanks.message }}
    </p>{% endif %}
    <a href="/" class="cd-btn cd-btn-primary mt-8 inline-flex text-sm">Back to home</a>
  </div>
</section>
