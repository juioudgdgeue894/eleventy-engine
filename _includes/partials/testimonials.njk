{# Based on testimonial-04 - dark 2-up grid with stars #}
<section class="bg-[var(--color-secondary)]">
  <div class="cd-container cd-section">
    <div class="flex flex-col gap-4 border-b border-white/10 pb-10 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">Testimonials</span>
        <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">What clients say</h2>
      </div>
    </div>
    <div class="mt-10 grid grid-cols-1 gap-px bg-white/[0.06] sm:grid-cols-2">
      {% for t in business.testimonials %}
      <div class="flex flex-col gap-6 bg-[var(--color-secondary)] p-8">
        {% if t.rating %}
        <div class="flex items-center gap-0.5" role="img" aria-label="{{ t.rating }} out of 5 stars">
          {% for i in range(1, 6) %}
          <svg class="h-3.5 w-3.5 {{ 'text-[var(--color-accent)]' if i <= t.rating else 'text-white/10' }}" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path d="M10 1l2.93 6.38 6.99.6-5.3 4.63 1.61 6.85L10 16.01l-6.23 3.45 1.61-6.85-5.3-4.63 6.99-.6L10 1z" />
          </svg>
          {% endfor %}
        </div>
        {% endif %}
        <p class="flex-1 text-[var(--color-body-text)]">&ldquo;{{ t.quote }}&rdquo;</p>
        <div>
          <p class="font-medium text-white">{{ t.name }}</p>
          <p class="text-sm text-[var(--color-body-text)]">{{ t.role }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
