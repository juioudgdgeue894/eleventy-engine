<section class="bg-white">
  <div class="cd-container cd-section">
    <div class="mx-auto grid max-w-lg grid-cols-1 gap-8 sm:max-w-none sm:grid-cols-3">
      {% for stat in business.stats %}
      <div class="flex flex-col rounded-lg bg-gray-50 px-4 py-8 text-center">
        <dt class="order-last text-lg text-gray-500">{{ stat.label }}</dt>
        <dd class="text-4xl text-[var(--color-accent-link)] md:text-5xl">{{ stat.value }}</dd>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
