{# Flowbite accordion - renders nothing if business.faq is empty. #}
{% if business.faq and business.faq.length %}
<section id="faq" class="">
  <div class="cd-container cd-section">
    <div class="flex flex-col gap-4 border-b border-white/10 pb-10 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">FAQs</span>
        <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">Frequently Asked Questions</h2>
      </div>
    </div>

    <div class="mx-auto mt-0 max-w-3xl" data-accordion="collapse" data-active-classes="" data-inactive-classes="">
      {% for item in business.faq %}
      <h3 id="faq-heading-{{ loop.index }}">
        <button type="button"
          class="group flex w-full items-center justify-between gap-3 border-b border-white/10 py-6 text-left"
          data-accordion-target="#faq-body-{{ loop.index }}"
          aria-expanded="{{ 'true' if loop.first else 'false' }}"
          aria-controls="faq-body-{{ loop.index }}">
          <span class="text-base font-semibold text-white group-hover:text-[var(--color-accent-link)] transition">{{ item.question }}</span>
          <span class="svc-acc-icon text-xl font-light text-[var(--color-body-text)]">+</span>
        </button>
      </h3>
      <div id="faq-body-{{ loop.index }}" class="{{ '' if loop.first else 'hidden' }}" aria-labelledby="faq-heading-{{ loop.index }}">
        <p class="py-6 text-[var(--color-body-text)]">{{ item.answer }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}
