<section id="pricing" class="bg-[var(--color-secondary)]">
  <div class="cd-container cd-section">
    <div class="flex flex-col gap-4 border-b border-white/10 pb-10 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">{{ business.sections.pricing.eyebrow }}</span>
        <h2 class="mt-3 text-3xl font-black text-white sm:text-4xl">{{ business.sections.pricing.heading }}</h2>
      </div>
      <p class="max-w-xs text-sm text-[var(--color-body-text)] sm:text-right">{{ business.sections.pricing.intro }}</p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-3">
      {% for plan in business.pricing %}
      <div class="relative {{ 'bg-[var(--color-primary)] text-white lg:-translate-y-2' if plan.featured else 'border border-white/10 bg-[var(--color-bg)]' }} p-6 sm:p-8">
        {% if plan.featured %}
        <span class="absolute -top-3 right-6 bg-[var(--color-accent)] px-3 py-1 text-xs font-semibold text-black">Most Popular</span>
        {% endif %}
        <span class="border {{ 'border-white/20 text-white/80' if plan.featured else 'border-white/10 text-[var(--color-body-text)]' }} px-3 py-1 text-xs">
          {{ plan.tier }}
        </span>
        <p class="mt-4">
          <strong class="text-3xl {{ 'text-white' if plan.featured else 'text-white' }}">{{ plan.price }}</strong>
          {% if plan.period %}<span class="text-sm {{ 'text-white/60' if plan.featured else 'text-[var(--color-body-text)]' }}">{{ plan.period }}</span>{% endif %}
        </p>
        <ul class="mt-6 space-y-2">
          {% for feature in plan.features %}
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 {{ 'text-white' if plan.featured else 'text-[var(--color-accent-link)]' }}" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            <span class="{{ 'text-white/90' if plan.featured else 'text-[var(--color-body-text)]' }}">{{ feature }}</span>
          </li>
          {% endfor %}
        </ul>
        <a class="cd-btn {{ 'cd-btn-light' if plan.featured else 'cd-btn-outline' }} mt-8 block text-center text-sm" href="{{ plan.cta_href }}">
          {{ plan.cta_label }}
        </a>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
