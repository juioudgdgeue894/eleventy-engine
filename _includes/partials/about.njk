{# Based on about-02 (two-column image + text) - adapted with dark bg and photo mosaic #}
<section id="about" class="bg-[var(--color-secondary)]">
  <div class="cd-container cd-section grid grid-cols-1 items-center gap-12 lg:grid-cols-2">

    {# Placeholder image mosaic. For production, drop real photos into src/images/
       and swap each <img> for the {% image %} shortcode, e.g.
       {% image "about-wide.jpg", "Alt text", "50vw", "h-full w-full object-cover" %} #}
    <div class="grid grid-cols-2 gap-4">
      <div class="col-span-2">
        <div class="cd-rounded-img overflow-hidden aspect-video">
          <img src="https://placehold.co/800x450?text=About+image+800x450" alt="[Describe the main about image]" class="h-full w-full object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
      <div>
        <div class="cd-rounded-img overflow-hidden aspect-square">
          <img src="https://placehold.co/400x400?text=Square+400x400" alt="[Describe this image]" class="h-full w-full object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
      <div>
        <div class="cd-rounded-img overflow-hidden aspect-square">
          <img src="https://placehold.co/400x400?text=Square+400x400" alt="[Describe this image]" class="h-full w-full object-cover" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>

    <div>
      <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-body-text)]">{{ business.sections.about.eyebrow }}</span>
      <h2 class="mt-3 text-3xl font-black leading-tight text-white sm:text-4xl">
        {{ business.about.heading }}
      </h2>

      <div class="mt-6 space-y-4 leading-relaxed text-[var(--color-body-text)]">
        {% for para in business.about.paragraphs %}
        <p>{{ para }}</p>
        {% endfor %}
      </div>

      {# Quick credibility badges — edit the list in business.about.badges #}
      {% if business.about.badges and business.about.badges.length %}
      <div class="mt-8 flex flex-wrap gap-2">
        {% for badge in business.about.badges %}
        <span class="inline-flex items-center gap-1.5 border border-white/10 px-3 py-1.5 text-xs text-[var(--color-body-text)]">{{ badge }}</span>
        {% endfor %}
      </div>
      {% endif %}

      <a class="cd-btn cd-btn-light mt-8 inline-block text-sm" href="{{ business.about.cta_href }}">
        {{ business.about.cta_label }}
      </a>
    </div>

  </div>
</section>
