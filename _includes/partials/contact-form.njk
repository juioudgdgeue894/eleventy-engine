{# Based on contact-02 - two-column intro + message form.
   This is the DESIGNED SECTION; the functional core (honeypot, labelled
   fields, error notice, Turnstile, guarded submit) is the shared
   partials/contact-fields.njk include, and the enhancement script (error
   reveal + double-submit guard) ships site-wide from base.njk.
   Handler is driven by business.forms.provider (default "cloudflare"):
     • "cloudflare" → posts to the /api/contact Pages Function, which sends the
        enquiry via Cloudflare Email Sending (see functions/api/contact.js).
     • "netlify"    → legacy Netlify Forms markup (data-netlify + hidden
        form-name), for sites not yet migrated to Cloudflare Pages. #}
{% set formProvider = business.forms.provider | default("cloudflare") %}

<section id="contact" class="bg-[var(--color-secondary)]">
  <div class="cd-container cd-section grid grid-cols-1 gap-12 lg:grid-cols-2">

    <div>
      <h2 class="text-2xl font-medium text-white sm:text-3xl">{{ business.sections.contact.side_heading }}</h2>
      <p class="mt-6 max-w-md leading-relaxed text-[var(--color-body-text)]">{{ business.sections.contact.side_text }}</p>
      <ul class="mt-8 space-y-3 text-sm">
        <li>
          <a class="inline-flex items-center gap-3 text-[var(--color-body-text)] transition hover:text-white" href="mailto:{{ business.contact.email }}">
            <svg class="h-4 w-4 text-[var(--color-accent-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
            {{ business.contact.email }}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h3 class="text-lg font-medium text-white">{{ business.sections.contact.heading }}</h3>
      {% if formProvider == "netlify" %}
      {# Legacy Netlify Forms handler #}
      <form class="mt-6 space-y-4" method="POST" action="/thanks/" name="contact" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        {% include "partials/contact-fields.njk" %}
      </form>
      {% else %}
      {# Cloudflare Pages Function handler → Cloudflare Email Sending #}
      <form class="mt-6 space-y-4" method="POST" action="/api/contact">
        {% include "partials/contact-fields.njk" %}
      </form>
      {% endif %}
    </div>

  </div>
</section>
