{# Based on contact-02 - two-column intro + message form.
   Form handler is driven by business.forms.provider (default "cloudflare"):
     • "cloudflare" → posts to the /api/contact Pages Function, which sends the
        enquiry via Cloudflare Email Sending (see functions/api/contact.js).
     • "netlify"    → legacy Netlify Forms markup (data-netlify + hidden
        form-name), for sites not yet migrated to Cloudflare Pages.
   Labels are visible and persistent (placeholders are never the only label).
   The handler redirects back with ?error=1 on validation/Turnstile failure —
   the notice below (data-cd-form-error) is unhidden by the inline script.
   The submit button disables itself on submit to prevent double sends. #}
{% set formProvider = business.forms.provider | default("cloudflare") %}

{# Shared input fields, reused by both handler variants. #}
{% set formFields %}
  {# Honeypot: hidden from real users, bots fill it in → submission discarded #}
  <p class="hidden" aria-hidden="true">
    <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </p>

  {# Error state: shown when /api/contact redirects back with ?error=1 #}
  <p class="hidden border-l-2 border-red-400 pl-3 text-sm text-red-400" data-cd-form-error role="alert">
    Something went wrong and your message wasn't sent. Please check your details and try again,
    or email us directly at <a class="underline" href="mailto:{{ business.contact.email }}">{{ business.contact.email }}</a>.
  </p>

  <div>
    <label class="mb-1.5 block text-sm font-medium text-white" for="name">Full name</label>
    <input class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-accent-link)] focus:outline-none" type="text" name="name" id="name" autocomplete="name" required />
  </div>
  <div>
    <label class="mb-1.5 block text-sm font-medium text-white" for="email">Email address</label>
    <input class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-accent-link)] focus:outline-none" type="email" name="email" id="email" autocomplete="email" required />
  </div>
  <div>
    <label class="mb-1.5 block text-sm font-medium text-white" for="message">Message</label>
    <textarea class="w-full rounded-[var(--radius-button)] border border-white/10 bg-[var(--color-bg)] p-3 text-sm text-white placeholder:text-[var(--color-body-text)] focus:border-[var(--color-accent-link)] focus:outline-none" rows="6" name="message" id="message" required></textarea>
  </div>

  {# Turnstile (opt-in): renders when business.forms.turnstile_site_key is set.
     Pair with the TURNSTILE_SECRET_KEY env var on the Pages/Worker project so
     /api/contact verifies the token — the widget alone blocks nothing. #}
  {% if business.forms.turnstile_site_key %}
    <div class="cf-turnstile" data-sitekey="{{ business.forms.turnstile_site_key }}" data-theme="{{ business.forms.turnstile_theme | default("dark") }}"></div>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  {% endif %}

  <button class="cd-btn cd-btn-primary w-full text-sm sm:w-auto" type="submit" data-cd-submit data-sending-label="Sending…">Send message</button>

  <p class="text-xs text-[var(--color-body-text)]">
    By sending this message you agree to our <a class="underline hover:text-white" href="/privacy-policy/">Privacy Policy</a>. We will only use your details to respond to your enquiry.
  </p>
{% endset %}

<section id="contact" class="bg-[var(--color-secondary)]">
  <div class="cd-container cd-section grid grid-cols-1 gap-12 lg:grid-cols-2">

    <div>
      <h2 class="text-2xl font-medium text-white sm:text-3xl">{{ business.sections.contact.side_heading }}</h2>
      <p class="mt-6 max-w-md leading-relaxed text-[var(--color-body-text)]">{{ business.sections.contact.side_text }}</p>
      <ul class="mt-8 space-y-3 text-sm">
        <li>
          <a class="inline-flex items-center gap-3 text-[var(--color-body-text)] transition hover:text-white" href="mailto:{{ business.contact.email }}">
            <svg class="h-4 w-4 text-[var(--color-accent-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
            {{ business.contact.email }}
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h3 class="text-lg font-medium text-white">{{ business.sections.contact.heading }}</h3>
      {% if formProvider == "netlify" %}
      {# Legacy Netlify Forms handler #}
      <form class="mt-6 space-y-4" method="POST" action="/thanks/" name="contact" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="contact" />
        {{ formFields | safe }}
      </form>
      {% else %}
      {# Cloudflare Pages Function handler → Cloudflare Email Sending #}
      <form class="mt-6 space-y-4" method="POST" action="/api/contact">
        {{ formFields | safe }}
      </form>
      {% endif %}
    </div>

  </div>
</section>

{# Progressive enhancement, shared by any form posting to the contact handler:
   1. reveal the error notice after an ?error=1 redirect back from /api/contact;
   2. disable the submit button once submission starts (prevents double sends)
      and swap its label for feedback. pageshow resets it for bfcache restores. #}
<script>
(function () {
  if (new URLSearchParams(location.search).has("error")) {
    document.querySelectorAll("[data-cd-form-error]").forEach(function (el) { el.classList.remove("hidden"); });
  }
  document.querySelectorAll("form[action=\"/api/contact\"], form[data-netlify]").forEach(function (f) {
    f.addEventListener("submit", function () {
      var b = f.querySelector("[data-cd-submit], button[type=submit]");
      if (!b || b.disabled) return;
      b.dataset.restoreLabel = b.textContent;
      b.textContent = b.dataset.sendingLabel || "Sending…";
      b.disabled = true;
    });
  });
  window.addEventListener("pageshow", function (e) {
    if (!e.persisted) return;
    document.querySelectorAll("[data-cd-submit][disabled], form button[type=submit][disabled]").forEach(function (b) {
      if (b.dataset.restoreLabel) b.textContent = b.dataset.restoreLabel;
      b.disabled = false;
    });
  });
})();
</script>
