{# Utility top bar — address / email / phone on the left, social icon chips on
   the right. Desktop only (hidden below md). Renders nothing unless
   business.utility_bar.enabled is true.

   business.json:
     "utility_bar": {
       "enabled": true,
       "show_address": true,
       "show_email": true,
       "show_phone": false
     }

   Background/foreground are themable per site:
     --color-utility-bar     (defaults to --color-secondary-dark)
     --color-utility-bar-on  (defaults to --color-body-text)              #}
{% if business.utility_bar and business.utility_bar.enabled %}
<div class="hidden bg-[var(--color-utility-bar,var(--color-secondary-dark))] text-[var(--color-utility-bar-on,var(--color-body-text))] md:block">
  <div class="cd-container flex items-center justify-between gap-6 py-2.5 text-sm">
    <div class="flex min-w-0 items-center gap-8">
      {% if business.utility_bar.show_address and business.address.line1 %}
      <a class="inline-flex min-w-0 items-center gap-2 transition hover:text-white" href="{{ business.address.map_url }}" target="_blank" rel="noopener">
        <svg class="h-4 w-4 shrink-0 text-[var(--color-accent-link)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
        <span class="truncate">{{ business.address.line1 }}, {{ business.address.city }} {{ business.address.postcode }}</span>
        <span class="sr-only"> (opens in new tab)</span>
      </a>
      {% endif %}
      {% if business.utility_bar.show_email and business.contact.email %}
      <a class="shrink-0 underline underline-offset-4 transition hover:text-white" href="mailto:{{ business.contact.email }}">{{ business.contact.email }}</a>
      {% endif %}
      {% if business.utility_bar.show_phone and business.contact.phone %}
      <a class="shrink-0 transition hover:text-white" href="{{ business.contact.phone_href }}">{{ business.contact.phone }}</a>
      {% endif %}
    </div>

    {% if business.social and business.social.length %}
    <ul class="flex shrink-0 items-center gap-2" aria-label="Social media">
      {% for s in business.social %}
      <li>
        <a class="flex h-7 w-7 items-center justify-center rounded text-white transition hover:opacity-85
          {%- if s.icon == 'facebook' %} bg-[#1877F2]
          {%- elif s.icon == 'instagram' %} bg-[#E1306C]
          {%- elif s.icon == 'x' %} bg-black
          {%- elif s.icon == 'tiktok' %} bg-black
          {%- elif s.icon == 'youtube' %} bg-[#FF0000]
          {%- elif s.icon == 'linkedin' %} bg-[#0A66C2]
          {%- else %} bg-white/10
          {%- endif %}" href="{{ s.url }}" target="_blank" rel="noopener">
          {%- if s.icon == 'facebook' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          {%- elif s.icon == 'instagram' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zm0 10.162a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          {%- elif s.icon == 'x' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          {%- elif s.icon == 'tiktok' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
          {%- elif s.icon == 'youtube' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          {%- elif s.icon == 'linkedin' -%}
          <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 1 1 0-4.123 2.062 2.062 0 0 1 0 4.123zM7.119 20.452H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/></svg>
          {%- else -%}
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
          {%- endif -%}
          <span class="sr-only">{{ s.label }} (opens in new tab)</span>
        </a>
      </li>
      {% endfor %}
    </ul>
    {% endif %}
  </div>
</div>
{% endif %}
