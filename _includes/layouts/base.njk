<!DOCTYPE html>
{#- Per-page frontmatter can override: title, description, og_image, og_type, noindex -#}
<html lang="{{ business.seo.locale }}">
<head>
<meta charset="UTF-8" />
<meta name="generator" content="@jacklamond/eleventy-engine v{{ engineVersion }}" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
{#- Append the business name as a title suffix, unless the page title already
   contains it (avoids "David Hughes … | David Hughes" duplication). -#}
{%- set _t = title or business.business_name -%}
{%- set fullTitle = _t if (business.business_name in _t) else _t + " | " + business.business_name -%}
<title>{{ fullTitle }}</title>
<meta name="description" content="{{ description or business.description }}" />
<meta name="robots" content="{{ 'noindex, nofollow' if noindex else 'index, follow' }}" />
<link rel="canonical" href="{{ business.seo.site_url }}{{ page.url }}" />

<!-- Open Graph -->
<meta property="og:type" content="{{ og_type or 'website' }}" />
<meta property="og:site_name" content="{{ business.business_name }}" />
<meta property="og:title" content="{{ fullTitle }}" />
<meta property="og:description" content="{{ description or business.description }}" />
<meta property="og:url" content="{{ business.seo.site_url }}{{ page.url }}" />
<meta property="og:image" content="{{ business.seo.site_url }}{{ og_image or business.seo.og_image }}" />
<meta property="og:locale" content="{{ business.seo.locale | replace('-', '_') }}" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ fullTitle }}" />
<meta name="twitter:description" content="{{ description or business.description }}" />
<meta name="twitter:image" content="{{ business.seo.site_url }}{{ og_image or business.seo.og_image }}" />
{% if business.seo.twitter_handle %}<meta name="twitter:site" content="{{ business.seo.twitter_handle }}" />{% endif %}

<!-- Favicon / theme -->
{#- /favicon.ico is emitted at the site root (see eleventy.js). Safari uses this
   raster icon; it will not render an SVG that wraps a raster image. Chrome and
   Firefox prefer the SVG below; sizes="any" stops them downloading the .ico. -#}
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png" />
<meta name="theme-color" content="{{ business.seo.theme_color }}" />

{#- Preload the fonts the site actually uses. Override per-site with
   business.seo.preload_fonts (array of .woff2 URLs); set [] to preload none.
   Defaults to the engine's NeueMontreal so existing sites are unchanged. -#}
{%- set preloadFonts = business.seo.preload_fonts or ["/fonts/NeueMontreal-Regular.woff2", "/fonts/NeueMontreal-Medium.woff2"] -%}
{% for font in preloadFonts -%}
<link rel="preload" href="{{ font }}" as="font" type="font/woff2" crossorigin />
{% endfor -%}
{#- LCP hero preload: pages with a full-bleed eager hero set `preload_image`
   (and optionally `preload_image_sizes`) in frontmatter so the image fetch
   starts before the render-blocking stylesheet finishes. -#}
{%- if preload_image %}
{% preload_image preload_image, preload_image_sizes or "100vw" %}
{%- endif %}
<link rel="stylesheet" href="/css/style.css" />
<link rel="alternate" type="application/atom+xml" href="/feed.xml" title="{{ business.business_name }} Blog" />

{% include "partials/schema.njk" %}
</head>
{#- Root-relative paths above/below need a real server: use `npm run dev`,
   not double-clicking _site/index.html. -#}
<body class="pb-16 sm:pb-0">

<a class="cd-skip-link" href="#main-content">Skip to main content</a>

{% include "partials/utility-bar.njk" %}
{% include "partials/announcement.njk" %}
{#- Chrome overrides: business.chrome.header / business.chrome.footer name a
   site-owned partial (e.g. "partials/mo-header.njk") to replace the engine
   chrome when CSS restyling isn't enough (mega menus, bespoke mastheads).
   The override must honour the same functional contract — see CLAUDE.shared.md. -#}
{% if business.chrome and business.chrome.header %}{% include business.chrome.header %}{% else %}{% include "partials/header.njk" %}{% endif %}

<main id="main-content">
{{ content | safe }}
</main>

{% if business.chrome and business.chrome.footer %}{% include business.chrome.footer %}{% else %}{% include "partials/footer.njk" %}{% endif %}
{% include "partials/mobile-cta.njk" %}
{% include "partials/cookie-banner.njk" %}

{#
  ── Contact-form enhancement (engine-owned, site-wide) ───────────────────────
  Works with ANY form posting to /api/contact (or legacy data-netlify), engine
  partial or site-owned custom markup:
  1. reveals [data-cd-form-error] after the handler redirects back with
     ?error=1 — and injects a plain fallback notice into forms that don't
     provide one (style it per-site with --color-error, or add your own
     data-cd-form-error element to control placement and copy);
  2. disables [data-cd-submit] (or the submit button) once submission starts,
     swapping its label for feedback — prevents double sends. pageshow resets
     it when the page is restored from the back/forward cache.
#}
<script>
(function () {
  var forms = document.querySelectorAll('form[action="/api/contact"], form[data-netlify]');
  if (!forms.length) return;
  var hasError = new URLSearchParams(location.search).has("error");
  forms.forEach(function (f) {
    var notice = f.querySelector("[data-cd-form-error]");
    if (!notice) {
      notice = document.createElement("p");
      notice.setAttribute("data-cd-form-error", "");
      notice.setAttribute("role", "alert");
      notice.hidden = true;
      notice.style.cssText = "border-left:2px solid var(--color-error,currentColor);padding-left:.75rem;font-size:.875rem;color:var(--color-error,inherit);";
      notice.textContent = "Something went wrong and your message wasn't sent. Please check your details and try again, or email us directly.";
      f.insertBefore(notice, f.firstChild);
    }
    if (hasError) { notice.hidden = false; notice.classList.remove("hidden"); }
    f.addEventListener("submit", function () {
      var b = f.querySelector("[data-cd-submit]") || f.querySelector('button[type="submit"]');
      if (!b || b.disabled) return;
      b.dataset.restoreLabel = b.innerHTML;
      b.textContent = b.dataset.sendingLabel || "Sending…";
      b.disabled = true;
    });
  });
  window.addEventListener("pageshow", function (e) {
    if (!e.persisted) return;
    document.querySelectorAll("form [data-cd-submit][disabled], form button[type=submit][disabled]").forEach(function (b) {
      if (b.dataset.restoreLabel) b.innerHTML = b.dataset.restoreLabel;
      b.disabled = false;
    });
  });
})();
</script>

{#
  ── Third-party / non-essential scripts ──────────────────────────────────────
  Analytics, pixels, chat widgets, A/B testing tools, and any other non-essential
  scripts MUST check cookie consent before loading. Unconditional loading violates PECR.

  Use this pattern (replace the comment with your actual snippet):

  <script>
    if (localStorage.getItem('cd-cookie-consent') === 'all') {
      // paste your analytics / marketing snippet here
    }
  </script>

  If you add external domains (e.g. www.googletagmanager.com, static.hotjar.com)
  you must also add them to the Content-Security-Policy in netlify.toml / vercel.json.
  ─────────────────────────────────────────────────────────────────────────────
#}
<script src="/js/flowbite.min.js" defer></script>
{%- if business.seo.cf_beacon_token %}
{#- Cloudflare Web Analytics — cookieless RUM beacon, so it needs no consent
   gate (unlike the third-party scripts above). Emitted in markup because
   Cloudflare's edge auto-injection does not rewrite Worker-served HTML.
   The site's _headers CSP must allow static.cloudflareinsights.com in
   script-src and cloudflareinsights.com in connect-src. Token = the RUM
   site_tag (dashboard → Web Analytics, or bin/launch-platform.mjs output). -#}
<script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ business.seo.cf_beacon_token }}"}'></script>
{%- endif %}
</body>
</html>
