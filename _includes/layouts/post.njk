---
layout: layouts/base.njk
og_type: article
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": {{ page.date | isoDate | dump | safe }},
  "dateModified": {{ page.date | isoDate | dump | safe }},
  "author": {
    "@type": "Person",
    "name": {{ business.built_by.name | dump | safe }},
    "url": {{ business.seo.site_url | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ business.business_name | dump | safe }},
    "url": {{ business.seo.site_url | dump | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ (business.seo.site_url + business.seo.og_image) | dump | safe }}
    }
  },
  "image": {{ (business.seo.site_url + business.seo.og_image) | dump | safe }},
  "mainEntityOfPage": {{ (business.seo.site_url + page.url) | dump | safe }}
}
</script>

<article>
  <header class="border-b border-white/10">
    <div class="cd-container mx-auto max-w-2xl pt-16 pb-12 sm:pt-20">
      <a class="inline-flex items-center gap-1.5 text-sm text-[var(--color-accent-link)] hover:text-white" href="/blog/">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
        All articles
      </a>
      <h1 class="mt-6 text-3xl font-medium leading-tight text-white sm:text-4xl">{{ title }}</h1>
      {% if description %}<p class="mt-4 text-lg leading-relaxed text-[var(--color-body-text)]">{{ description }}</p>{% endif %}
      <div class="mt-6 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-[var(--color-body-text)]">
        <span>By {{ business.built_by.name }}</span>
        <span aria-hidden="true">&middot;</span>
        <span>{{ content | readingTime }} min read</span>
      </div>
    </div>
  </header>

  <div class="cd-container mx-auto max-w-2xl py-12 sm:py-16">
    <div class="prose max-w-none">
      {{ content | safe }}
    </div>
  </div>

  {# Lead-gen CTA - every post ends with a clear next step #}
  <div class="cd-container mx-auto max-w-2xl pb-20">
    <div class="rounded-[var(--radius-image)] border border-white/10 bg-[var(--color-secondary)] p-8 text-center sm:p-10">
      <h2 class="text-xl font-medium text-white sm:text-2xl">{{ business.sections.contact.side_heading }}</h2>
      <p class="mx-auto mt-3 max-w-md text-[var(--color-body-text)]">{{ business.sections.contact.side_text }}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a class="cd-btn cd-btn-primary text-sm" href="/#contact">{{ business.cta_header.label }}</a>
        <a class="cd-btn cd-btn-outline text-sm" href="/blog/">Read more articles</a>
      </div>
    </div>
  </div>
</article>
