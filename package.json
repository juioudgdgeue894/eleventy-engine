{
  "name": "@jacklamond/eleventy-engine",
  "version": "1.18.6",
  "description": "Shared Eleventy engine — layouts, partials, SEO scaffolding, component library and UK compliance — for client websites.",
  "type": "commonjs",
  "main": "eleventy.js",
  "exports": {
    ".": "./eleventy.js",
    "./eleventy": "./eleventy.js",
    "./tailwind-preset": "./tailwind-preset.js"
  },
  "bin": {
    "eleventy-engine-sync": "bin/sync.mjs"
  },
  "scripts": {
    "sync:all": "node bin/sync-all.mjs",
    "release": "node bin/release.mjs",
    "launch:platform": "node bin/launch-platform.mjs"
  },
  "files": [
    "eleventy.js",
    "tailwind-preset.js",
    "bin/",
    "_includes/",
    "pages/",
    "css/",
    "functions/",
    "worker/",
    "CLAUDE.shared.md",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "concurrently": "^9.0.0",
    "flowbite": "^2.5.2",
    "tailwindcss": "^3.4.13"
  }
}
